@model T1_Aldana_Roger.Models.Distribuidor

@{
    ViewData["Title"] = "Crear Distribuidor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Crear</h1>

<form method="post" asp-action="Crear">
    <div class="border p-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group row">
            <h2 class="text-info pl-3">Nuevo Distribuidor</h2>
        </div>

        <div class="container">
            <div class="mb-3">
                <label asp-for="NombreDistribuidor" class="form-label">Nombre Distribuidor</label>
                <input asp-for="NombreDistribuidor" class="form-control" />
                <span asp-validation-for="NombreDistribuidor" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RazonSocial" class="form-label">Razón Social</label>
                <input asp-for="RazonSocial" class="form-control" />
                <span asp-validation-for="RazonSocial" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefono" class="form-label">Teléfono</label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AnioInicioOperacion" class="form-label">Año Inicio Operación</label>
                <input asp-for="AnioInicioOperacion" class="form-control" />
                <span asp-validation-for="AnioInicioOperacion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contacto" class="form-label">Contacto</label>
                <input asp-for="Contacto" class="form-control" />
                <span asp-validation-for="Contacto" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 d-md-block">
                <button type="submit" class="btn btn-primary">Crear Nuevo</button>
                <a asp-controller="Distribuidor" asp-action="Index" class="btn btn-success">Regresar</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}