@model T1_Aldana_Roger.Models.Distribuidor

@{
    ViewData["Title"] = "Eliminar Distribuidor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Eliminar</h1>

<form method="post" asp-action="Eliminar">
    <input asp-for="Id" hidden />

    <div class="border p-3">
        <div class="form-group row">
            <h2 class="text-info pl-3">¿Está seguro de eliminar este Distribuidor?</h2>
        </div>

        <div class="container">
            <div class="mb-3">
                <label asp-for="NombreDistribuidor" class="form-label">Nombre Distribuidor</label>
                <input asp-for="NombreDistribuidor" disabled class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="RazonSocial" class="form-label">Razón Social</label>
                <input asp-for="RazonSocial" disabled class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Telefono" class="form-label">Teléfono</label>
                <input asp-for="Telefono" disabled class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="AnioInicioOperacion" class="form-label">Año Inicio Operación</label>
                <input asp-for="AnioInicioOperacion" disabled class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Contacto" class="form-label">Contacto</label>
                <input asp-for="Contacto" disabled class="form-control" />
            </div>

            <div class="d-grid gap-2 d-md-block">
                <button type="submit" class="btn btn-danger">Eliminar</button>
                <a asp-controller="Distribuidor" asp-action="Index" class="btn btn-success">Regresar</a>
            </div>
        </div>
    </div>
</form>