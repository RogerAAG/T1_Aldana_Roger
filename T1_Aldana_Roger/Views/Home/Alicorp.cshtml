@{
    ViewData["Title"] = "Alicorp - Perú";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow p-4">
        <h1 class="text-primary">Alicorp - Distribuidor conocido en el Perú</h1>

        <p class="mt-3">
            Alicorp es una empresa peruana reconocida en el rubro de consumo masivo, alimentos,
            cuidado del hogar, cuidado personal y soluciones para negocios. Es conocida por sus
            marcas presentes en hogares, bodegas, restaurantes y empresas del Perú.
        </p>

        <p>
            Su importancia como distribuidor y proveedor radica en que permite abastecer diferentes
            canales comerciales con productos de alta rotación, apoyando tanto al consumidor final
            como a negocios que necesitan productos para su operación diaria.
        </p>

        <div class="text-center my-4">
            <img src="~/img/alicorp.jpg"
                 class="img-fluid rounded shadow"
                 style="max-height:250px;"
                 alt="Imagen de Alicorp" />
        </div>

        <h3 class="text-secondary">Video relacionado</h3>

        <div class="ratio ratio-16x9">
            <iframe src="https://www.youtube.com/embed/fkyYGZOZE74"
                    title="Video institucional Alicorp"
                    allowfullscreen>
            </iframe>
        </div>
    </div>
</div>