@{
    ViewData["Title"] = "Ingram Micro - Mundo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow p-4">
        <h1 class="text-primary">Ingram Micro - Distribuidor mundial de tecnología</h1>

        <p class="mt-3">
            Ingram Micro es una empresa global dedicada a la distribución de productos tecnológicos,
            soluciones en la nube, servicios B2B y apoyo a proveedores, fabricantes y revendedores
            de tecnología.
        </p>

        <p>
            Su rol como distribuidor es importante porque permite que productos y servicios
            tecnológicos lleguen a empresas, tiendas, integradores y clientes en diferentes países
            del mundo.
        </p>

        <div class="text-center my-4">
            <img src="https://logo.clearbit.com/ingrammicro.com"
                 class="img-fluid rounded shadow"
                 style="max-height:250px;"
                 alt="Imagen de Ingram Micro" />
        </div>

        <h3 class="text-secondary">Video relacionado</h3>

        <div class="ratio ratio-16x9">
            <iframe src="https://www.youtube.com/embed/z2W0pT5fB_Q"
                    title="Video Ingram Micro"
                    allowfullscreen>
            </iframe>
        </div>
    </div>
</div>