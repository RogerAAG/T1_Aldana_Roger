@{
    ViewData["Title"] = "Sysco - Mundo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow p-4">
        <h1 class="text-primary">Sysco - Distribuidor mundial de alimentos</h1>

        <p class="mt-3">
            Sysco es una empresa internacional dedicada a la venta, comercialización y distribución
            de alimentos y productos relacionados. Atiende principalmente a restaurantes, hoteles,
            hospitales, centros educativos y otros negocios que preparan alimentos fuera del hogar.
        </p>

        <p>
            Es considerada una de las empresas más importantes del mundo en distribución de alimentos,
            ya que conecta productores, almacenes, transporte y clientes mediante una amplia red
            logística.
        </p>

        <div class="text-center my-4">
            <img src="https://logo.clearbit.com/sysco.com"
                 class="img-fluid rounded shadow"
                 style="max-height:250px;"
                 alt="Imagen de Sysco" />
        </div>

        <h3 class="text-secondary">Video relacionado</h3>

        <div class="ratio ratio-16x9">
            <iframe src="https://www.youtube.com/embed/wvcoVDQlIHc"
                    title="Video de distribución Sysco"
                    allowfullscreen>
            </iframe>
        </div>
    </div>
</div>